// backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
  // output Zeile entfernt -> landet standardmäßig in node_modules
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Hier beginnen unsere Tabellen ---

model Recipe {
  id           Int      @id @default(autoincrement())
  title        String
  description  String?
  sourceUrl    String   @unique
  imageUrl     String?  // Externe URL (bleibt als Fallback)
  imageData    Bytes?   // Binäre Bilddaten (BLOB)
  imageType    String?  // Content-Type (z.B. image/jpeg)
  servings     Int      @default(4)
  prepTime     Int?     // in Minuten
  calories     Int?     // Kalorien pro Rezept
  
  // Relationen
  ingredients  Ingredient[]
  instructions Instruction[]
  mealPlans    MealPlan[]
  categories   Category[]
  dailyRecipe  DailyRecipe?
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Category {
  id      Int      @id @default(autoincrement())
  name    String   @unique
  recipes Recipe[]
}

model DailyRecipe {
  id        Int      @id @default(autoincrement())
  date      DateTime @unique @default(now())
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  recipeId  Int      @unique
}

model Ingredient {
  id             Int     @id @default(autoincrement())
  name           String
  normalizedName String?
  amount         Float?
  unit           String?
  
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  recipeId Int
}

model Instruction {
  id       Int    @id @default(autoincrement())
  step     Int
  text     String
  
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  recipeId Int
}

model MealPlan {
  id        Int      @id @default(autoincrement())
  date      DateTime // Das Wichtigste: Wann wird gekocht?
  
  // Verknüpfung zum Rezept
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  recipeId  Int

  // Optional: Wenn du später User hast
  // userId Int
  
  // Damit man an einem Tag nicht aus Versehen 2 Gerichte speichert (optional)
  @@unique([date]) 
}

model SearchHistory {
  id          Int      @id @default(autoincrement())
  term        String
  filterCount Int      @default(0)
  filters     Json?    // Stores { time: Int, ingredients: String[] }
  createdAt   DateTime @default(now())

  @@index([createdAt])
}
